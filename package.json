{
  "name": "@jaypie/monorepo",
  "version": "1.2.1",
  "private": true,
  "license": "MIT",
  "author": "Finlayson Studio",
  "type": "module",
  "workspaces": [
    "packages/*",
    "workspaces/*"
  ],
  "scripts": {
    "build": "npm run build:core-deps && npm run build:packages && npm run build:workspaces",
    "build:aws": "npm run build --workspace packages/aws",
    "build:constructs": "npm run build --workspace packages/constructs",
    "build:core": "npm run build --workspace packages/core",
    "build:core-deps": "npm run build -w packages/types && npm run build -w packages/errors && npm run build -w packages/fabric && npm run build -w packages/constructs && npm run build -w packages/kit && npm run build -w packages/logger",
    "build:datadog": "npm run build --workspace packages/datadog",
    "build:errors": "npm run build --workspace packages/errors",
    "build:express": "npm run build --workspace packages/express",
    "build:jaypie": "npm run build --workspace packages/jaypie",
    "build:lambda": "npm run build --workspace packages/lambda",
    "build:llm": "npm run build --workspace packages/llm",
    "build:mcp": "npm run build --workspace packages/mcp",
    "build:packages": "for dir in packages/*/; do npm run build --if-present -w \"$dir\"; done",
    "build:testkit": "npm run build --workspace packages/testkit",
    "build:textract": "npm run build --workspace packages/textract",
    "build:types": "npm run build --workspace packages/types",
    "build:webkit": "npm run build --workspace packages/webkit",
    "build:workspaces": "for dir in workspaces/*/; do npm run build --if-present -w \"$dir\"; done",
    "clean": "rimraf ./packages/*/dist",
    "deploy:documentation:sandbox": "npm run deploy:documentation:sandbox --workspace workspaces/cdk",
    "dev:documentation": "npm run start --workspace workspaces/documentation",
    "docker:express": "npm run docker:build --workspace packages/express && npm run docker:run --workspace packages/express",
    "docker:express:build": "npm run docker:build --workspace packages/express",
    "docker:express:run": "npm run docker:run --workspace packages/express",
    "docs:build": "npm run build --workspace workspaces/documentation",
    "docs:extract": "npm run extract --workspace workspaces/documentation",
    "docs:serve": "npm run serve --workspace workspaces/documentation",
    "docs:start": "npm run start --workspace workspaces/documentation",
    "format": "npm run format:package && npm run format:lint",
    "format:lint": "eslint --fix .",
    "format:package": "sort-package-json ./package.json ./packages/*/package.json ./workspaces/*/package.json",
    "lint": "eslint --quiet .",
    "test": "vitest run",
    "test:aws": "npm run test --workspace packages/aws",
    "test:cdk": "npm run test --workspace packages/cdk",
    "test:constructs": "npm run test --workspace packages/constructs",
    "test:core": "npm run test --workspace packages/core",
    "test:datadog": "npm run test --workspace packages/datadog",
    "test:errors": "npm run test --workspace packages/errors",
    "test:eslint": "npm run test --workspace packages/eslint",
    "test:express": "npm run test --workspace packages/express",
    "test:jaypie": "npm run test --workspace packages/jaypie",
    "test:lambda": "npm run test --workspace packages/lambda",
    "test:llm": "npm run test --workspace packages/llm",
    "test:llm:all": "tsx packages/llm/test/document.ts && tsx packages/llm/test/image.ts && tsx packages/llm/test/joke.ts && tsx packages/llm/test/reasoning.ts && tsx packages/llm/test/structured.ts",
    "test:llm:document": "tsx packages/llm/test/document.ts",
    "test:llm:image": "tsx packages/llm/test/image.ts",
    "test:llm:joke": "tsx packages/llm/test/joke.ts",
    "test:llm:matrix": "tsx packages/llm/test/matrix.ts",
    "test:llm:matrix:bedrock": "npm run test:matrix:bedrock -w packages/llm",
    "test:llm:reasoning": "tsx packages/llm/test/reasoning.ts",
    "test:llm:structured": "tsx packages/llm/test/structured.ts",
    "test:testkit": "npm run test --workspace packages/testkit",
    "test:textract": "npm run test --workspace packages/textract",
    "test:types": "npm run test --workspace packages/types",
    "test:webkit": "npm run test --workspace packages/webkit",
    "typecheck": "npm run typecheck --workspaces"
  },
  "overrides": {
    "@microsoft/api-documenter": {
      "js-yaml": "^4.3.0"
    },
    "eslint-plugin-import": {
      "eslint": "$eslint"
    },
    "next": {
      "postcss": "^8.5.15"
    },
    "serialize-javascript": "^7.0.5",
    "sockjs": {
      "uuid": "^14.0.1"
    },
    "yaml-language-server": {
      "yaml": "^2.9.0"
    }
  },
  "devDependencies": {
    "@jaypie/eslint": "*",
    "@jaypie/repokit": "*",
    "@jaypie/testkit": "*",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.0.0",
    "js-yaml": "^4.3.0",
    "prettier": "^3.3.3",
    "rollup": "^4.24.0",
    "rollup-plugin-auto-external": "^2.0.0",
    "supertest": "^7.0.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.8"
  }
}
