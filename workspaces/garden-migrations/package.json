{
  "name": "@jaypie/garden-migrations",
  "version": "0.1.0",
  "private": true,
  "description": "DynamoDB migrations for Jaypie Garden",
  "license": "MIT",
  "author": "Finlayson Studio",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
